##################################################
# HOLLOW PURPLE PLATFORM METADATA
##################################################

HP_SYSTEM_NAME=HOLLOW_PURPLE
HP_SYSTEM_VERSION=1.0.0
HP_ENVIRONMENT=production
HP_REGION=global
HP_DEPLOYMENT_ID=cluster-alpha


##################################################
# KERNEL CONFIGURATION
##################################################

HP_KERNEL_WORKERS=8
HP_KERNEL_STARTUP_TIMEOUT=60
HP_KERNEL_SHUTDOWN_TIMEOUT=30


##################################################
# LOGGING
##################################################

HP_LOG_LEVEL=INFO
HP_LOG_FORMAT=json
HP_LOG_FILE_ENABLED=false
HP_LOG_MAX_FILE_MB=50
HP_LOG_RETENTION_DAYS=7


##################################################
# API SERVER
##################################################

HP_API_HOST=0.0.0.0
HP_API_PORT=8080
HP_API_WORKERS=8
HP_API_TIMEOUT_SECONDS=30
HP_API_MAX_CONNECTIONS=5000


##################################################
# SECURITY
##################################################

HP_SECURITY_ENABLE_ATTACK_DETECTION=true
HP_SECURITY_ENABLE_AUDIT_TRAIL=true
HP_SECURITY_MAX_REQUEST_MB=25
HP_SECURITY_JWT_SECRET=CHANGE_THIS_SECRET
HP_SECURITY_JWT_EXPIRATION_MINUTES=60


##################################################
# AUTHENTICATION
##################################################

HP_AUTH_ENABLE_API_KEYS=true
HP_AUTH_ENABLE_JWT=true
HP_AUTH_RATE_LIMIT_PER_MINUTE=300


##################################################
# REDIS CACHE
##################################################

HP_REDIS_HOST=localhost
HP_REDIS_PORT=6379
HP_REDIS_DB=0
HP_REDIS_MAX_CONNECTIONS=200


##################################################
# INGESTION PIPELINE
##################################################

HP_INGESTION_WORKERS=6
HP_INGESTION_QUEUE_SIZE=20000
HP_INGESTION_BATCH_SIZE=500
HP_INGESTION_RATE_LIMIT=3000
HP_INGESTION_BACKPRESSURE_THRESHOLD=0.8


##################################################
# INGESTION RELIABILITY
##################################################

HP_INGESTION_RETRY_MAX=5
HP_INGESTION_RETRY_DELAY_SECONDS=3
HP_INGESTION_DEAD_LETTER_ENABLED=true
HP_INGESTION_DEDUP_WINDOW_SECONDS=60


##################################################
# EVENT PROCESSING
##################################################

HP_EVENT_MAX_SIZE_KB=256
HP_EVENT_TTL_SECONDS=86400
HP_EVENT_VALIDATION_STRICT=true


##################################################
# GRAPH ENGINE
##################################################

HP_GRAPH_MAX_NODES=100000
HP_GRAPH_MAX_EDGES=1000000
HP_GRAPH_PATH_MAX_DEPTH=8
HP_GRAPH_REBUILD_INTERVAL_SECONDS=120
HP_GRAPH_TEMPORAL_WINDOW_SECONDS=7200


##################################################
# ATTACK PATH ANALYSIS
##################################################

HP_ATTACK_PATH_MAX_LENGTH=8
HP_ATTACK_PATH_MAX_BRANCHING=10
HP_ATTACK_PATH_TIMEOUT_SECONDS=5


##################################################
# BASELINE ENGINE
##################################################

HP_BASELINE_TRAINING_WINDOW_DAYS=14
HP_BASELINE_UPDATE_INTERVAL_SECONDS=3600
HP_BASELINE_DRIFT_THRESHOLD=0.35


##################################################
# IDENTITY ANALYTICS
##################################################

HP_IDENTITY_ENTROPY_THRESHOLD=0.6
HP_IDENTITY_DORMANT_DAYS=30
HP_IDENTITY_MAX_PRIVILEGE_CHAIN=5


##################################################
# RISK ENGINE
##################################################

HP_RISK_MAX_SCORE=100
HP_RISK_HIGH_THRESHOLD=70
HP_RISK_CRITICAL_THRESHOLD=90


##################################################
# PATTERN DETECTION
##################################################

HP_PATTERN_LATERAL_MOVEMENT_ENABLED=true
HP_PATTERN_PRIV_ESCALATION_ENABLED=true
HP_PATTERN_TOKEN_ABUSE_ENABLED=true


##################################################
# SNAPSHOT ENGINE
##################################################

HP_SNAPSHOT_INTERVAL_SECONDS=300
HP_SNAPSHOT_RETENTION_COUNT=100
HP_SNAPSHOT_COMPRESSION_ENABLED=true


##################################################
# REPLAY ENGINE
##################################################

HP_REPLAY_MAX_EVENTS=100000
HP_REPLAY_TIMEOUT_SECONDS=60
HP_REPLAY_PARALLEL_WORKERS=4


##################################################
# MAHORAGA VERIFICATION SYSTEM
##################################################

HP_MERKLE_TREE_FANOUT=2
HP_MERKLE_HASH_ALGORITHM=sha256
HP_SIGNED_TREE_HEAD_INTERVAL_SECONDS=60
HP_AUDIT_VERIFICATION_INTERVAL_SECONDS=120


##################################################
# CONSENSUS CLUSTER
##################################################

HP_CONSENSUS_ENABLED=false
HP_CONSENSUS_CLUSTER_SIZE=3
HP_CONSENSUS_TIMEOUT_SECONDS=5


##################################################
# WITNESS NODES
##################################################

HP_WITNESS_NODE_ENABLED=false
HP_WITNESS_NODE_PORT=9001


##################################################
# ALERT STREAMING
##################################################

HP_ALERT_STREAM_ENABLED=true
HP_ALERT_QUEUE_SIZE=5000
HP_STREAM_HEARTBEAT_SECONDS=20


##################################################
# STORAGE PATHS
##################################################

HP_STORAGE_EVENT_PATH=data/events
HP_STORAGE_GRAPH_PATH=data/graph
HP_STORAGE_SNAPSHOT_PATH=data/snapshots
HP_STORAGE_BASELINE_PATH=data/baselines
HP_STORAGE_INTEGRITY_PATH=data/integrity


##################################################
# DATABASE (OPTIONAL)
##################################################

HP_DB_HOST=localhost
HP_DB_PORT=5432
HP_DB_NAME=hollow_purple
HP_DB_USER=hp_admin
HP_DB_PASSWORD=CHANGE_THIS_PASSWORD


##################################################
# TELEMETRY
##################################################

HP_METRICS_ENABLED=true
HP_METRICS_PORT=9100
HP_TELEMETRY_INTERVAL_SECONDS=30


##################################################
# PROMETHEUS
##################################################

HP_PROMETHEUS_ENABLED=true
HP_PROMETHEUS_PORT=9090


##################################################
# HEALTH CHECKS
##################################################

HP_HEALTHCHECK_INTERVAL_SECONDS=30
HP_HEALTHCHECK_TIMEOUT_SECONDS=5


##################################################
# SIMULATION MODE (Testing)
##################################################

HP_SIMULATION_MODE=false
HP_SIMULATION_EVENTS=10000
HP_SIMULATION_ATTACK_SPEED=1.0


##################################################
# DEBUG
##################################################

HP_DEBUG_MODE=false
HP_ENABLE_PROFILING=false